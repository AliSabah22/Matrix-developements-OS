// prisma/schema.prisma
// Database schema for Matrix OS persistence

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// PROJECTS — the three active projects + any created later
// ============================================================
model Project {
  id             String   @id @default(cuid())
  slug           String   @unique // "wraptors-saas", "archstudio", etc.
  name           String
  description    String?
  status         String   @default("active") // active, paused, archived
  clientType     String?  // "client" or "internal"
  githubOwner    String?
  githubRepo     String?
  defaultBranch  String   @default("dev")
  wikiPage       String?  // path in vault, e.g. "projects/wraptors-saas.md"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  tasks          Task[]
  orchestrations Orchestration[]

  @@index([status])
  @@index([slug])
}

// ============================================================
// SESSIONS — one per agent+project combination, persistent
// projectSlug stores the project slug ("wraptors-saas", etc.) or null for all-projects scope
// ============================================================
model Session {
  id            String   @id @default(cuid())
  agentId       String   // "ceo-strategy", "developer", etc.
  projectSlug   String?  // project slug, e.g. "wraptors-saas" (null = all-projects scope)
  title         String?  // auto-generated from first message, editable
  isPinned      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastMessageAt DateTime @default(now()) // for sorting by recency

  // Relations
  messages    Message[]

  @@index([agentId, projectSlug])
  @@index([lastMessageAt])
  @@index([agentId])
}

// ============================================================
// MESSAGES — every message in every session, in order
// ============================================================
model Message {
  id        String   @id @default(cuid())
  sessionId String
  role      String   // "user" or "assistant"
  content   String   // the actual message content
  metadata  String?  // JSON: model used, tokens, tool calls, etc.
  createdAt DateTime @default(now())

  // Relations
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

// ============================================================
// TASKS — work assigned to agents, tracked on the dashboard
// ============================================================
model Task {
  id              String   @id @default(cuid())
  projectId       String?
  agentId         String?
  title           String
  description     String?
  status          String   @default("queued") // queued, in_progress, blocked, done, cancelled
  priority        String   @default("medium") // low, medium, high, critical
  parentTaskId    String?  // for subtasks
  orchestrationId String?  // if created by orchestrator
  prUrl           String?  // GitHub PR if applicable
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  completedAt     DateTime?

  // Relations
  project       Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  orchestration Orchestration? @relation(fields: [orchestrationId], references: [id], onDelete: SetNull)
  parentTask    Task?          @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks      Task[]         @relation("TaskSubtasks")

  @@index([status])
  @@index([agentId])
  @@index([projectId])
  @@index([orchestrationId])
}

// ============================================================
// ORCHESTRATIONS — multi-agent runs from the orchestrator page
// ============================================================
model Orchestration {
  id          String   @id @default(cuid())
  projectId   String?
  userPrompt  String   // the original request
  status      String   @default("running") // running, completed, failed, cancelled
  summary     String?  // final summary produced by orchestrator
  createdAt   DateTime @default(now())
  completedAt DateTime?

  // Relations
  project    Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  tasks      Task[]
  activities AgentActivity[]

  @@index([status])
  @@index([createdAt])
}

// ============================================================
// AGENT ACTIVITY — live log for the dashboard activity feed
// ============================================================
model AgentActivity {
  id              String   @id @default(cuid())
  agentId         String
  orchestrationId String?
  taskId          String?
  activityType    String   // started, message, tool_call, completed, error
  content         String
  timestamp       DateTime @default(now())

  // Relations
  orchestration Orchestration? @relation(fields: [orchestrationId], references: [id], onDelete: Cascade)

  @@index([timestamp])
  @@index([agentId])
}
